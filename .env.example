DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# Use sqlite for local dev (default) or PostgreSQL:
# DATABASE_URL=postgres://njangi:njangi@localhost:5432/njangi_trust

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Celo blockchain integration (see blockchain_contracts/README.md) ---
# Leave BLOCKCHAIN_ENABLED=False to use simulated transaction hashes.
BLOCKCHAIN_ENABLED=False
CELO_NETWORK=alfajores
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org
CELO_PRIVATE_KEY=
CELO_LEDGER_CONTRACT_ADDRESS=
CELO_EXPLORER_BASE_URL=https://alfajores.celoscan.io/tx/

# --- MTN MoMo webhook (stub) ---
MOMO_WEBHOOK_SECRET=dev-momo-secret

# --- Push notifications (Firebase Cloud Messaging, HTTP v1) ---
# Path to your Firebase service-account JSON file. When unset, push sending is a
# no-op and only in-app notifications are created. Download the file from the
# Firebase console → Project Settings → Service Accounts → Generate new
# private key. Keep this file OUT of version control.
FIREBASE_CREDENTIALS=secrets/firebase-service-account.json
